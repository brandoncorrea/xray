{
  "name": "xray",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "xray": "./src/cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "mutate": "node scripts/mutate.js",
    "mutate:all": "node scripts/mutate.js --all --parallel 4 --json reports/mutation/all.json",
    "mutate:all:json": "node scripts/mutate.js --all --parallel 4 --json",
    "mutate:incremental": "node scripts/mutate.js --incremental --json",
    "mutate:diff": "node scripts/mutate.js --diff",
    "coverage": "vitest run --coverage",
    "coverage:open": "vitest run --coverage && open coverage/index.html"
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "acorn-jsx": "^5.3.2",
    "madge": "^8.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "mutagen": "github:brandoncorrea/mutagen",
    "vitest": "^4.1.4"
  }
}
