{
  "name": "xray",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "xray": "./src/cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "mutate": "mutagen --incremental --progress --parallel 8 --json reports/mutation/all.json",
    "test:coverage": "vitest run --coverage",
    "test:coverage:open": "vitest run --coverage && open coverage/index.html"
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "acorn-jsx": "^5.3.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "@bwawan/mutagen": "^0.1.0",
    "vitest": "^4.1.4"
  }
}
